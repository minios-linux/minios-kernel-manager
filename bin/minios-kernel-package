#!/bin/sh
#
# MiniOS Kernel Packager Launcher
# This script launches the kernel packaging application
#

set -e

# Find the real directory of the script
SCRIPT_DIR=$(dirname "$(readlink -f -- "$0")")

# Check for installed location first
if [ -f "/usr/lib/minios-kernel-manager/kernel_packager.py" ]; then
    DIR="/usr/lib/minios-kernel-manager"
else
    # Assume running from source, construct path relative to this script
    DIR="$(dirname "$SCRIPT_DIR")/lib"
fi

exec python3 -u "$DIR/kernel_packager.py" "$@"